rules_version = '2';

// ================================================================
// AUDICOM HUB — Regras de Segurança Firestore
//
// Modelo de segurança em camadas (enforcement no BANCO, não só na UI):
//
//  1) MEMBRO ATIVO: só acessa quem tem users/{uid} e não está
//     `bloqueado`. Usuário excluído/bloqueado perde acesso na hora.
//  2) ISOLAMENTO POR PROJETO: só lê/escreve as coleções de um projeto
//     quem tem esse projeto liberado em users/{uid}.projects[proj]
//     (admin sempre). Um cliente de um projeto NÃO enxerga outro.
//  3) PROTEÇÃO DO PRÓPRIO DOC: um usuário comum NÃO pode alterar
//     campos sensíveis do próprio users/{uid} (role, permissions,
//     projects, bloqueado, ...). Impede auto-promoção a admin ou
//     auto-desbloqueio via console. Só pode mexer em campos neutros
//     (ex.: cpf). Criar/apagar/rebaixar usuário = só admin.
//  4) PERMISSÕES GRANULARES no que o banco consegue distinguir com
//     segurança: `adicionar/criar` (create), `apagar permanente`
//     (delete na lixeira) e cliente-externo da ronda (somente leitura).
//  5) GLOBAIS (config, projetos-lista, categorias-usuarios): leitura
//     p/ membros ativos, escrita só admin.
//
// LIMITAÇÃO CONHECIDA (decisão de projeto — enforcement fica na UI):
//   Dentro de um projeto que o usuário JÁ acessa, `editar` /
//   `reordenar` / `mover p/ lixeira` são o MESMO `update` de documento
//   (às vezes em arrays), então o banco não separa a intenção sem
//   quebrar fluxos. Essas sub-ações continuam controladas visualmente.
//   O banco garante o que importa contra abuso: quem não tem o projeto
//   não entra, cliente é read-only, ninguém se auto-promove, e apagar
//   permanente exige a permissão certa.
// ================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers base ----------
    function isAuth() { return request.auth != null; }

    function existeMeuDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function meuDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Membro ativo = autenticado + doc existe + não bloqueado.
    function isMembroAtivo() {
      return isAuth() && existeMeuDoc() && meuDoc().get('bloqueado', false) != true;
    }

    function meuRole() { return meuDoc().get('role', 'user'); }
    function isAdmin() {
      return isMembroAtivo() && (meuRole() == 'admin' || meuRole() == 'superadmin');
    }

    // Acesso ao projeto: projects[proj] == true (admin sempre).
    function temProjeto(proj) {
      return isAdmin()
        || (isMembroAtivo() && meuDoc().get('projects', {}).get(proj, false) == true);
    }

    // Permissão granular efetiva (espelha resolverPermissoes):
    // admin => sempre true; senão valor salvo; senão o default informado.
    function permsProjeto(proj) { return meuDoc().get('permissions', {}).get(proj, {}); }
    function pode(proj, cap, def) {
      return isAdmin() || (isMembroAtivo() && permsProjeto(proj).get(cap, def) == true);
    }

    // Cliente externo da ronda = somente leitura no respectivo projeto.
    function isClienteCallink() {
      return isMembroAtivo() && meuDoc().get('rondaCallinkCliente', false) == true;
    }
    function isClienteLinkcall() {
      return isMembroAtivo() && meuDoc().get('rondaLinkcallCliente', false) == true;
    }
    function isClienteBarueri() {
      return isMembroAtivo() && meuDoc().get('rondaBarueriCliente', false) == true;
    }
    function isClienteJundiai() {
      return isMembroAtivo() && meuDoc().get('rondaJundiaiCliente', false) == true;
    }

    function statusRonda(dados) {
      return dados.get('status', 'concluida');
    }
    function textoPreenchido(valor) {
      return valor is string && valor.size() > 0;
    }
    function rondaConcluidaCompleta(dados) {
      return textoPreenchido(dados.get('localId', ''))
        && textoPreenchido(dados.get('tecnicoUid', ''))
        && dados.get('dataRonda', null) is timestamp
        && dados.get('horaInicio', null) is timestamp
        && dados.get('horaTermino', null) is timestamp;
    }
    function statusRondaValido(dados) {
      return statusRonda(dados) in ['rascunho', 'concluida']
        && (statusRonda(dados) == 'rascunho' || rondaConcluidaCompleta(dados));
    }
    function isMinhaRonda(dados) {
      return isAuth()
        && (dados.get('tecnicoUid', '') == request.auth.uid
            || dados.get('criadoPorUid', '') == request.auth.uid);
    }

    function rondaCallink(rid) {
      return get(/databases/$(database)/documents/ronda-callink-rondas/$(rid)).data;
    }
    function podeLerRondaCallink(dados) {
      return temProjeto('ronda-callink')
        && (isAdmin()
            || statusRonda(dados) == 'concluida'
            || (!isClienteCallink() && isMinhaRonda(dados)));
    }
    function podeCriarRondaCallink(dados) {
      return !isClienteCallink()
        && pode('ronda-callink', 'registrarRonda', true)
        && statusRondaValido(dados)
        && (isAdmin() || isMinhaRonda(dados));
    }
    function podeAtualizarRondaCallink() {
      return !isClienteCallink()
        && statusRondaValido(request.resource.data)
        && (isAdmin()
            || (isMinhaRonda(resource.data)
                && isMinhaRonda(request.resource.data)
                && pode('ronda-callink', 'registrarRonda', true))
            || (statusRonda(resource.data) == 'concluida'
                && (pode('ronda-callink', 'registrarRonda', true)
                    || pode('ronda-callink', 'editar', false)
                    || pode('ronda-callink', 'moverLixeira', true)
                    || pode('ronda-callink', 'restaurar', true))));
    }
    function podeEscreverFotoCallink(rid) {
      return !isClienteCallink()
        && (isAdmin()
            || (isMinhaRonda(rondaCallink(rid))
                && pode('ronda-callink', 'registrarRonda', true))
            || (statusRonda(rondaCallink(rid)) == 'concluida'
                && (pode('ronda-callink', 'registrarRonda', true)
                    || pode('ronda-callink', 'editar', false))));
    }

    function rondaLinkcall(rid) {
      return get(/databases/$(database)/documents/ronda-linkcall-rondas/$(rid)).data;
    }
    function podeLerRondaLinkcall(dados) {
      return temProjeto('ronda-linkcall')
        && (isAdmin()
            || statusRonda(dados) == 'concluida'
            || (!isClienteLinkcall() && isMinhaRonda(dados)));
    }
    function podeCriarRondaLinkcall(dados) {
      return !isClienteLinkcall()
        && pode('ronda-linkcall', 'registrarRonda', true)
        && statusRondaValido(dados)
        && (isAdmin() || isMinhaRonda(dados));
    }
    function podeAtualizarRondaLinkcall() {
      return !isClienteLinkcall()
        && statusRondaValido(request.resource.data)
        && (isAdmin()
            || (isMinhaRonda(resource.data)
                && isMinhaRonda(request.resource.data)
                && pode('ronda-linkcall', 'registrarRonda', true))
            || (statusRonda(resource.data) == 'concluida'
                && (pode('ronda-linkcall', 'registrarRonda', true)
                    || pode('ronda-linkcall', 'editar', false)
                    || pode('ronda-linkcall', 'moverLixeira', true)
                    || pode('ronda-linkcall', 'restaurar', true))));
    }
    function podeEscreverFotoLinkcall(rid) {
      return !isClienteLinkcall()
        && (isAdmin()
            || (isMinhaRonda(rondaLinkcall(rid))
                && pode('ronda-linkcall', 'registrarRonda', true))
            || (statusRonda(rondaLinkcall(rid)) == 'concluida'
                && (pode('ronda-linkcall', 'registrarRonda', true)
                    || pode('ronda-linkcall', 'editar', false))));
    }

    function rondaBarueri(rid) {
      return get(/databases/$(database)/documents/ronda-barueri-rondas/$(rid)).data;
    }
    function podeLerRondaBarueri(dados) {
      return temProjeto('ronda-barueri')
        && (isAdmin()
            || statusRonda(dados) == 'concluida'
            || (!isClienteBarueri() && isMinhaRonda(dados)));
    }
    function podeCriarRondaBarueri(dados) {
      return !isClienteBarueri()
        && pode('ronda-barueri', 'registrarRonda', true)
        && statusRondaValido(dados)
        && (isAdmin() || isMinhaRonda(dados));
    }
    function podeAtualizarRondaBarueri() {
      return !isClienteBarueri()
        && statusRondaValido(request.resource.data)
        && (isAdmin()
            || (isMinhaRonda(resource.data)
                && isMinhaRonda(request.resource.data)
                && pode('ronda-barueri', 'registrarRonda', true))
            || (statusRonda(resource.data) == 'concluida'
                && (pode('ronda-barueri', 'registrarRonda', true)
                    || pode('ronda-barueri', 'editar', false)
                    || pode('ronda-barueri', 'moverLixeira', true)
                    || pode('ronda-barueri', 'restaurar', true))));
    }
    function podeEscreverFotoBarueri(rid) {
      return !isClienteBarueri()
        && (isAdmin()
            || (isMinhaRonda(rondaBarueri(rid))
                && pode('ronda-barueri', 'registrarRonda', true))
            || (statusRonda(rondaBarueri(rid)) == 'concluida'
                && (pode('ronda-barueri', 'registrarRonda', true)
                    || pode('ronda-barueri', 'editar', false))));
    }

    function rondaJundiai(rid) {
      return get(/databases/$(database)/documents/ronda-jundiai-rondas/$(rid)).data;
    }
    function podeLerRondaJundiai(dados) {
      return temProjeto('ronda-jundiai')
        && (isAdmin()
            || statusRonda(dados) == 'concluida'
            || (!isClienteJundiai() && isMinhaRonda(dados)));
    }
    function podeCriarRondaJundiai(dados) {
      return !isClienteJundiai()
        && pode('ronda-jundiai', 'registrarRonda', true)
        && statusRondaValido(dados)
        && (isAdmin() || isMinhaRonda(dados));
    }
    function podeAtualizarRondaJundiai() {
      return !isClienteJundiai()
        && statusRondaValido(request.resource.data)
        && (isAdmin()
            || (isMinhaRonda(resource.data)
                && isMinhaRonda(request.resource.data)
                && pode('ronda-jundiai', 'registrarRonda', true))
            || (statusRonda(resource.data) == 'concluida'
                && (pode('ronda-jundiai', 'registrarRonda', true)
                    || pode('ronda-jundiai', 'editar', false)
                    || pode('ronda-jundiai', 'moverLixeira', true)
                    || pode('ronda-jundiai', 'restaurar', true))));
    }
    function podeEscreverFotoJundiai(rid) {
      return !isClienteJundiai()
        && (isAdmin()
            || (isMinhaRonda(rondaJundiai(rid))
                && pode('ronda-jundiai', 'registrarRonda', true))
            || (statusRonda(rondaJundiai(rid)) == 'concluida'
                && (pode('ronda-jundiai', 'registrarRonda', true)
                    || pode('ronda-jundiai', 'editar', false))));
    }

    // Update mexe SOMENTE nos campos listados (usado p/ proteger users).
    function apenasCampos(campos) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(campos);
    }

    // ================================================================
    // USERS — o ponto mais sensível para um sistema com clientes.
    // ================================================================
    match /users/{uid} {
      // O próprio usuário sempre lê o próprio doc (mesmo bloqueado, p/ a
      // sessão detectar o bloqueio e deslogar). Demais docs: membro ativo
      // (o app lista técnicos/clientes e o painel admin lê a lista).
      allow read: if isAuth() && (request.auth.uid == uid || isMembroAtivo());

      // Contas são criadas/excluídas apenas pelo admin (app secundário).
      allow create, delete: if isAdmin();

      allow update: if
        // admin gerencia role, permissions, projects, bloqueado, categoria...
        isAdmin()
        // o próprio usuário só altera campos NEUTROS (nunca role/permissions/
        // projects/bloqueado). Hoje só o CPF é auto-editável.
        || (isMembroAtivo() && request.auth.uid == uid && apenasCampos(['cpf']))
        // gestão de acessos de clientes da Ronda Callink (aba do projeto):
        // quem tem gerenciarClientes só pode tocar nesses 2 campos de outro doc.
        || (pode('ronda-callink', 'gerenciarClientes', false)
            && apenasCampos(['rondaCallinkCliente', 'rondaCallinkLocais']))
        // idem Ronda Linkcall.
        || (pode('ronda-linkcall', 'gerenciarClientes', false)
            && apenasCampos(['rondaLinkcallCliente', 'rondaLinkcallLocais']))
        // idem Ronda Callink Barueri.
        || (pode('ronda-barueri', 'gerenciarClientes', false)
            && apenasCampos(['rondaBarueriCliente', 'rondaBarueriLocais']))
        // idem Ronda Callink Jundiaí.
        || (pode('ronda-jundiai', 'gerenciarClientes', false)
            && apenasCampos(['rondaJundiaiCliente', 'rondaJundiaiLocais']));
    }

    // ================================================================
    // GLOBAIS — administradas pelo admin.html; leitura p/ membros.
    // ================================================================
    match /config/{doc} {
      allow read:  if isMembroAtivo();
      allow write: if isAdmin();
    }
    match /projetos-lista/{doc} {
      allow read:  if isMembroAtivo();
      allow write: if isAdmin();
    }
    match /categorias-usuarios/{doc} {
      allow read:  if isMembroAtivo();
      allow write: if isAdmin();
    }

    // ================================================================
    // HUBSOFT — credenciais da API (client_secret, senha) = CRÍTICO.
    //   Fica FORA de `config/` de propósito: config/ é legível por
    //   qualquer membro ativo (inclusive clientes de ronda). Aqui a
    //   leitura exige o projeto sistema-chamados + a permissão granular
    //   `hubsoftConsultar` (default negado; admin sempre). Assim quem
    //   não consulta chamados — em especial clientes externos — não
    //   alcança as credenciais nem via console. Escrita só admin.
    // ================================================================
    match /hubsoft/{doc} {
      allow read:  if isAdmin()
                   || (temProjeto('sistema-chamados')
                       && pode('sistema-chamados', 'hubsoftConsultar', false));
      allow write: if isAdmin();
    }

    // ================================================================
    // PROJETOS sob projetos/{proj}/... (conteúdo + subcoleções)
    //   create  -> requer a permissão de "adicionar/criar" do projeto
    //   update  -> membro com o projeto (editar/reordenar/lixeira = UI)
    //   delete  -> membro com o projeto (remoção normal de item)
    //   permanente fica nas coleções lixeira-* (abaixo)
    // ================================================================
    match /projetos/suporte-roteadores/{document=**} {
      allow read:          if temProjeto('suporte-roteadores');
      allow create:        if pode('suporte-roteadores', 'adicionar', true);
      allow update, delete : if temProjeto('suporte-roteadores');
    }
    match /projetos/suporte-operacoes/{document=**} {
      allow read:          if temProjeto('suporte-operacoes');
      allow create:        if pode('suporte-operacoes', 'adicionar', true);
      allow update, delete : if temProjeto('suporte-operacoes');
    }
    match /projetos/agregador-links/{document=**} {
      allow read:          if temProjeto('agregador-links');
      allow create:        if pode('agregador-links', 'adicionar', true);
      allow update, delete : if temProjeto('agregador-links');
    }
    match /projetos/solicitacao-manutencoes/{document=**} {
      allow read:          if temProjeto('solicitacao-manutencoes');
      allow create:        if pode('solicitacao-manutencoes', 'criar', true);
      // status/painel adm é controlado na UI (painelAdm); membro com o
      // projeto pode atualizar sua própria solicitação.
      allow update, delete : if temProjeto('solicitacao-manutencoes');
    }
    match /projetos/sistema-chamados/{document=**} {
      allow read:  if temProjeto('sistema-chamados');
      allow write: if temProjeto('sistema-chamados');
    }

    // Lixeiras dos projetos acima (coleções top-level):
    //   create -> moverLixeira | update -> restaurar | delete -> apagarPermanente
    match /lixeira-roteadores/{id} {
      allow read:   if temProjeto('suporte-roteadores');
      allow create: if pode('suporte-roteadores', 'moverLixeira', true);
      allow update: if pode('suporte-roteadores', 'restaurar', true);
      allow delete: if pode('suporte-roteadores', 'apagarPermanente', false);
    }
    match /lixeira-operacoes/{id} {
      allow read:   if temProjeto('suporte-operacoes');
      allow create: if pode('suporte-operacoes', 'moverLixeira', true);
      allow update: if pode('suporte-operacoes', 'restaurar', true);
      allow delete: if pode('suporte-operacoes', 'apagarPermanente', false);
    }
    match /lixeira-links/{id} {
      allow read:   if temProjeto('agregador-links');
      allow create: if pode('agregador-links', 'moverLixeira', true);
      allow update: if pode('agregador-links', 'restaurar', true);
      allow delete: if pode('agregador-links', 'apagarPermanente', false);
    }

    // ================================================================
    // RONDA CALLINK (coleções top-level próprias)
    //   Cliente externo (rondaCallinkCliente) = SOMENTE LEITURA.
    // ================================================================
    match /ronda-callink-locais/{lid} {
      allow read:          if temProjeto('ronda-callink');
      allow create, update : if !isClienteCallink()
                              && (pode('ronda-callink', 'gerenciarLocais', false)
                                  || pode('ronda-callink', 'moverLixeira', true)
                                  || pode('ronda-callink', 'restaurar', true));
      allow delete:        if !isClienteCallink()
                              && (pode('ronda-callink', 'gerenciarLocais', false)
                                  || pode('ronda-callink', 'apagarPermanente', false));
    }
    match /ronda-callink-locais/{lid}/catracas/{cid} {
      allow read:                 if temProjeto('ronda-callink');
      allow create, update, delete : if !isClienteCallink()
                                     && pode('ronda-callink', 'gerenciarLocais', false);
    }
    match /ronda-callink-produtos/{pid} {
      allow read:          if temProjeto('ronda-callink');
      allow create, update : if !isClienteCallink()
                              && (pode('ronda-callink', 'gerenciarProdutos', false)
                                  || pode('ronda-callink', 'moverLixeira', true)
                                  || pode('ronda-callink', 'restaurar', true));
      allow delete:        if !isClienteCallink()
                              && (pode('ronda-callink', 'gerenciarProdutos', false)
                                  || pode('ronda-callink', 'apagarPermanente', false));
    }
    match /ronda-callink-rondas/{rid} {
      allow read:   if podeLerRondaCallink(resource.data);
      allow create: if podeCriarRondaCallink(request.resource.data);
      // editar ronda + marcar deletado (lixeira) + restaurar são updates.
      allow update: if podeAtualizarRondaCallink();
      allow delete: if !isClienteCallink() && pode('ronda-callink', 'apagarPermanente', false);
    }
    match /ronda-callink-rondas/{rid}/fotos/{fid} {
      allow read:                 if podeLerRondaCallink(rondaCallink(rid));
      // fotos são criadas/removidas ao registrar/editar a ronda.
      allow create, update, delete : if podeEscreverFotoCallink(rid);
    }
    match /lixeira-ronda-callink/{id} {
      allow read:   if temProjeto('ronda-callink');
      allow create: if !isClienteCallink() && pode('ronda-callink', 'moverLixeira', true);
      allow update: if !isClienteCallink() && pode('ronda-callink', 'restaurar', true);
      allow delete: if !isClienteCallink() && pode('ronda-callink', 'apagarPermanente', false);
    }
    match /ronda-callink-logs/{id} {
      allow read:   if temProjeto('ronda-callink') && pode('ronda-callink', 'visualizarLogs', false);
      allow create: if temProjeto('ronda-callink')
                    && request.resource.data.projeto == 'ronda-callink'
                    && request.resource.data.usuarioUid == request.auth.uid
                    && request.resource.data.criadoEm == request.time;
      allow update, delete: if false;
    }

    // ================================================================
    // RONDA LINKCALL (clone independente — prefixo ronda-linkcall)
    // ================================================================
    match /ronda-linkcall-locais/{lid} {
      allow read:          if temProjeto('ronda-linkcall');
      allow create, update : if !isClienteLinkcall()
                              && (pode('ronda-linkcall', 'gerenciarLocais', false)
                                  || pode('ronda-linkcall', 'moverLixeira', true)
                                  || pode('ronda-linkcall', 'restaurar', true));
      allow delete:        if !isClienteLinkcall()
                              && (pode('ronda-linkcall', 'gerenciarLocais', false)
                                  || pode('ronda-linkcall', 'apagarPermanente', false));
    }
    match /ronda-linkcall-locais/{lid}/catracas/{cid} {
      allow read:                 if temProjeto('ronda-linkcall');
      allow create, update, delete : if !isClienteLinkcall()
                                     && pode('ronda-linkcall', 'gerenciarLocais', false);
    }
    match /ronda-linkcall-produtos/{pid} {
      allow read:          if temProjeto('ronda-linkcall');
      allow create, update : if !isClienteLinkcall()
                              && (pode('ronda-linkcall', 'gerenciarProdutos', false)
                                  || pode('ronda-linkcall', 'moverLixeira', true)
                                  || pode('ronda-linkcall', 'restaurar', true));
      allow delete:        if !isClienteLinkcall()
                              && (pode('ronda-linkcall', 'gerenciarProdutos', false)
                                  || pode('ronda-linkcall', 'apagarPermanente', false));
    }
    match /ronda-linkcall-rondas/{rid} {
      allow read:   if podeLerRondaLinkcall(resource.data);
      allow create: if podeCriarRondaLinkcall(request.resource.data);
      allow update: if podeAtualizarRondaLinkcall();
      allow delete: if !isClienteLinkcall() && pode('ronda-linkcall', 'apagarPermanente', false);
    }
    match /ronda-linkcall-rondas/{rid}/fotos/{fid} {
      allow read:                 if podeLerRondaLinkcall(rondaLinkcall(rid));
      allow create, update, delete : if podeEscreverFotoLinkcall(rid);
    }
    match /lixeira-ronda-linkcall/{id} {
      allow read:   if temProjeto('ronda-linkcall');
      allow create: if !isClienteLinkcall() && pode('ronda-linkcall', 'moverLixeira', true);
      allow update: if !isClienteLinkcall() && pode('ronda-linkcall', 'restaurar', true);
      allow delete: if !isClienteLinkcall() && pode('ronda-linkcall', 'apagarPermanente', false);
    }
    match /ronda-linkcall-logs/{id} {
      allow read:   if temProjeto('ronda-linkcall') && pode('ronda-linkcall', 'visualizarLogs', false);
      allow create: if temProjeto('ronda-linkcall')
                    && request.resource.data.projeto == 'ronda-linkcall'
                    && request.resource.data.usuarioUid == request.auth.uid
                    && request.resource.data.criadoEm == request.time;
      allow update, delete: if false;
    }

    // ================================================================
    // RONDA CALLINK BARUERI (clone independente — prefixo ronda-barueri)
    // ================================================================
    match /ronda-barueri-locais/{lid} {
      allow read:          if temProjeto('ronda-barueri');
      allow create, update : if !isClienteBarueri()
                              && (pode('ronda-barueri', 'gerenciarLocais', false)
                                  || pode('ronda-barueri', 'moverLixeira', true)
                                  || pode('ronda-barueri', 'restaurar', true));
      allow delete:        if !isClienteBarueri()
                              && (pode('ronda-barueri', 'gerenciarLocais', false)
                                  || pode('ronda-barueri', 'apagarPermanente', false));
    }
    match /ronda-barueri-locais/{lid}/catracas/{cid} {
      allow read:                 if temProjeto('ronda-barueri');
      allow create, update, delete : if !isClienteBarueri()
                                     && pode('ronda-barueri', 'gerenciarLocais', false);
    }
    match /ronda-barueri-produtos/{pid} {
      allow read:          if temProjeto('ronda-barueri');
      allow create, update : if !isClienteBarueri()
                              && (pode('ronda-barueri', 'gerenciarProdutos', false)
                                  || pode('ronda-barueri', 'moverLixeira', true)
                                  || pode('ronda-barueri', 'restaurar', true));
      allow delete:        if !isClienteBarueri()
                              && (pode('ronda-barueri', 'gerenciarProdutos', false)
                                  || pode('ronda-barueri', 'apagarPermanente', false));
    }
    match /ronda-barueri-rondas/{rid} {
      allow read:   if podeLerRondaBarueri(resource.data);
      allow create: if podeCriarRondaBarueri(request.resource.data);
      allow update: if podeAtualizarRondaBarueri();
      allow delete: if !isClienteBarueri() && pode('ronda-barueri', 'apagarPermanente', false);
    }
    match /ronda-barueri-rondas/{rid}/fotos/{fid} {
      allow read:                 if podeLerRondaBarueri(rondaBarueri(rid));
      allow create, update, delete : if podeEscreverFotoBarueri(rid);
    }
    match /lixeira-ronda-barueri/{id} {
      allow read:   if temProjeto('ronda-barueri');
      allow create: if !isClienteBarueri() && pode('ronda-barueri', 'moverLixeira', true);
      allow update: if !isClienteBarueri() && pode('ronda-barueri', 'restaurar', true);
      allow delete: if !isClienteBarueri() && pode('ronda-barueri', 'apagarPermanente', false);
    }
    match /ronda-barueri-logs/{id} {
      allow read:   if temProjeto('ronda-barueri') && pode('ronda-barueri', 'visualizarLogs', false);
      allow create: if temProjeto('ronda-barueri')
                    && request.resource.data.projeto == 'ronda-barueri'
                    && request.resource.data.usuarioUid == request.auth.uid
                    && request.resource.data.criadoEm == request.time;
      allow update, delete: if false;
    }

    // ================================================================
    // RONDA CALLINK JUNDIAÍ (clone independente — prefixo ronda-jundiai)
    // ================================================================
    match /ronda-jundiai-locais/{lid} {
      allow read:          if temProjeto('ronda-jundiai');
      allow create, update : if !isClienteJundiai()
                              && (pode('ronda-jundiai', 'gerenciarLocais', false)
                                  || pode('ronda-jundiai', 'moverLixeira', true)
                                  || pode('ronda-jundiai', 'restaurar', true));
      allow delete:        if !isClienteJundiai()
                              && (pode('ronda-jundiai', 'gerenciarLocais', false)
                                  || pode('ronda-jundiai', 'apagarPermanente', false));
    }
    match /ronda-jundiai-locais/{lid}/catracas/{cid} {
      allow read:                 if temProjeto('ronda-jundiai');
      allow create, update, delete : if !isClienteJundiai()
                                     && pode('ronda-jundiai', 'gerenciarLocais', false);
    }
    match /ronda-jundiai-produtos/{pid} {
      allow read:          if temProjeto('ronda-jundiai');
      allow create, update : if !isClienteJundiai()
                              && (pode('ronda-jundiai', 'gerenciarProdutos', false)
                                  || pode('ronda-jundiai', 'moverLixeira', true)
                                  || pode('ronda-jundiai', 'restaurar', true));
      allow delete:        if !isClienteJundiai()
                              && (pode('ronda-jundiai', 'gerenciarProdutos', false)
                                  || pode('ronda-jundiai', 'apagarPermanente', false));
    }
    match /ronda-jundiai-rondas/{rid} {
      allow read:   if podeLerRondaJundiai(resource.data);
      allow create: if podeCriarRondaJundiai(request.resource.data);
      allow update: if podeAtualizarRondaJundiai();
      allow delete: if !isClienteJundiai() && pode('ronda-jundiai', 'apagarPermanente', false);
    }
    match /ronda-jundiai-rondas/{rid}/fotos/{fid} {
      allow read:                 if podeLerRondaJundiai(rondaJundiai(rid));
      allow create, update, delete : if podeEscreverFotoJundiai(rid);
    }
    match /lixeira-ronda-jundiai/{id} {
      allow read:   if temProjeto('ronda-jundiai');
      allow create: if !isClienteJundiai() && pode('ronda-jundiai', 'moverLixeira', true);
      allow update: if !isClienteJundiai() && pode('ronda-jundiai', 'restaurar', true);
      allow delete: if !isClienteJundiai() && pode('ronda-jundiai', 'apagarPermanente', false);
    }
    match /ronda-jundiai-logs/{id} {
      allow read:   if temProjeto('ronda-jundiai') && pode('ronda-jundiai', 'visualizarLogs', false);
      allow create: if temProjeto('ronda-jundiai')
                    && request.resource.data.projeto == 'ronda-jundiai'
                    && request.resource.data.usuarioUid == request.auth.uid
                    && request.resource.data.criadoEm == request.time;
      allow update, delete: if false;
    }

    // ================================================================
    // HISTÓRICO DE CHAMADOS — log de auditoria IMUTÁVEL.
    //   Coleção top-level própria (fica FORA da regra ampla de
    //   projetos/sistema-chamados p/ poder negar update/delete).
    //   Cria quem tem o projeto (e só como si mesmo); NINGUÉM edita ou
    //   apaga — nem admin. Clientes de ronda (sem o projeto) não leem.
    //   Link público: docs com publico:true são legíveis por ID direto
    //   (get), mas a coleção inteira (list) continua protegida.
    // ================================================================
    match /chamados-historico/{docId} {
      // Leitura irrestrita para permitir que o link público funcione via REST
      allow get: if true;
      allow list: if request.auth != null && temProjeto('sistema-chamados');
      allow create: if request.auth != null && temProjeto('sistema-chamados');
      // Historico é imutável: update/delete não são permitidos
      allow update, delete: if false;

      // Subcoleção de comentários do chamado (usado no link público)
      match /comentarios/{commentId} {
        // Leitura livre para exibir no link público (que não exige autenticação)
        allow read: if true;
        // Apenas membros ativos podem adicionar novos comentários (via SDK de Auth)
        allow create: if isMembroAtivo();
        // Comentários não podem ser editados ou apagados (auditoria)
        allow update, delete: if false;
      }
    }

    // ================================================================
    // PUBLICO-CONFIG — configurações legíveis publicamente (sem auth).
    //   Contém apenas dados não sensíveis como hash de senha pública.
    //   Escrita exclusiva de admin.
    // ================================================================
    match /publico-config/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ================================================================
    // CATCH-ALL: qualquer coleção não mapeada acima fica acessível
    // apenas para admin (rede de segurança — não abre nada a clientes).
    // ================================================================
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
