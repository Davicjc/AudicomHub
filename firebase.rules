rules_version = '2';

// ================================================================
// AUDICOM HUB — Regras de Segurança Firestore
//
// Modelo: qualquer usuário autenticado (login + senha) tem acesso
// total ao sistema. Restrições por role (user/admin/superadmin)
// são aplicadas apenas na UI/HTML — não no Firestore.
// ================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    match /{document=**} {
      allow read, write: if isAuth();
    }
  }
}
